{
  "name": "achim-benzel-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:projects": "tsx scripts/generate-projects.ts",
    "sync:reference-projects": "tsx scripts/sync-reference-projects.ts",
    "dev": "npm run generate:projects && vite --configLoader runner",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.node.json",
    "build": "npm run generate:projects && npm run typecheck && vite build --configLoader runner",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
